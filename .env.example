# Telegram
BOT_TOKEN=your-telegram-bot-token

# Text model
LLM_PROVIDER=openai
CHAT_MODEL=gpt-5-mini
LLM_API_KEY=your-openai-api-key
LLM_BASE_URL=

# Gemini, only if you choose LLM_PROVIDER=gemini or TRANSCRIBE_PROVIDER=gemini
GEMINI_API_KEY=

# Voice
# none = disabled
# openai = use OpenAI transcription with LLM_API_KEY
# gemini = requires GEMINI_API_KEY
TRANSCRIBE_PROVIDER=openai
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
TRANSCRIBE_API_KEY=
TRANSCRIBE_BASE_URL=

# App
DB_PATH=data/tldr.db
RATE_LIMIT_PER_MIN=10
MAX_INPUT_CHARS=20000
